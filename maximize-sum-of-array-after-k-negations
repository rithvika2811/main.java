class Solution {
    public int largestSumAfterKNegations(int[] nums, int k) {
        int n=nums.length;
        Arrays.sort(nums);
        for(int i=0;i<n&&k>0;i++){ 
            if(nums[i]<0){
                nums[i]*=-1;
                k--;
            }
        }
        if(k%2==1 ){  
        Arrays.sort(nums);
        nums[0]*=-1;
        } 
        int sum=0;
        for(int num:nums){
            sum=sum + num;
        } 
        return sum;
    }
}
